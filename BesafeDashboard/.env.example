# ── MongoDB Atlas
MONGO_URI='your_mongodb_connection_string'

# ── Flask / Server
PORT=5000
DEBUG=True
SECRET_KEY='your_flask_secret'

# ── NLP model (your hosted endpoint)
NLP_API_URL=https://besafev1.onrender.com/predict

# ── JWT (agency dashboard — Flask-JWT-Extended)
JWT_SECRET='your_jwt_secret'

# ── JWT (mobile app tokens)
JWT_ACCESS_SECRET='your_access_token_secret'
JWT_REFRESH_SECRET='your_refresh_token_secret'
JWT_ACCESS_TOKEN_EXPIRATION=1800
JWT_REFRESH_TOKEN_EXPIRATION=604800
JWT_REFRESH_TOKEN_EXPIRATION_DB=2592000

# ── Cloudinary (profile picture uploads)
CLOUDINARY_CLOUD_NAME='your_cloud_name'
CLOUDINARY_API_KEY='your_api_key'
CLOUDINARY_API_SECRET='your_api_secret'

# ── Mailjet (email)
MAILJET_API_KEY='your_mailjet_key'
MAILJET_API_SECRET='your_mailjet_secret'
EMAIL_FROM='your_from_email'

# ── Twilio (SMS)
TWILIO_ACCOUNT_SID='your_twilio_sid'
TWILIO_AUTH_TOKEN='your_twilio_token'
TWILIO_PHONE_NUMBER='your_twilio_number'

# ── Africa's Talking SMS (for family alerts)
SMS_USERNAME='your_africastalking_username'
SMS_API_KEY='your_africastalking_api_key'
